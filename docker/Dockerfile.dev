FROM python:3.10-slim-bullseye

ARG TZ='Asia/Shanghai'
ARG APT_MIRROR=''

ENV DEBIAN_FRONTEND=noninteractive
ENV BUILD_PREFIX=/app
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

WORKDIR ${BUILD_PREFIX}

# 系统依赖
RUN if [ -n "${APT_MIRROR}" ] && [ -f /etc/apt/sources.list ]; then \
        sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list; \
        sed -i "s|security.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list; \
    fi \
    && apt-get update --fix-missing \
    && apt-get install -y --no-install-recommends curl ca-certificates git make \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# uv 包管理器
RUN /usr/local/bin/python -m pip install --upgrade pip \
    && /usr/local/bin/python -m pip install "uv>=0.5" --no-cache-dir \
        -i https://pypi.tuna.tsinghua.edu.cn/simple

# venv 放在 /opt 避开 volume 挂载，构建时预装依赖
RUN uv venv /opt/venv

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project --active

# 启动脚本
COPY docker/entrypoint-dev.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["tail", "-f", "/dev/null"]
